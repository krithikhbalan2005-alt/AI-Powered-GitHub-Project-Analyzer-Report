PORT=5000
NODE_ENV=development
FRONTEND_URL=https://ai-powered-git-hub-project-analyzer.vercel.app

# Firebase Configuration
FIREBASE_PROJECT_ID=ai-powered-github-project
FIREBASE_CLIENT_EMAIL=your-firebase-client-email@ai-powered-github-project.iam.gserviceaccount.com
# Replace \n with actual newlines or write them in quotes, handled by the code
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvgIBADANBgkqhkiG9w0BAQEFAASCBKgwggSkAgEAAoIBAQC...\n-----END PRIVATE KEY-----\n"

# GitHub REST API
GITHUB_TOKEN=your_github_personal_access_token_here

# Google Gemini API
GEMINI_API_KEY=your_gemini_api_key_here

# Admin / Security Settings
# Comma-separated list of Firebase UIDs of administrators
ADMIN_UIDS=admin_uid_1,admin_uid_2
REPORT_SIGNED_URL_EXPIRATION_MINUTES=60
