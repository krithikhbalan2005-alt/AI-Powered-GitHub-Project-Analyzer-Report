        {
          "name": "Get Analyses History list",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{idToken}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/analyses?limit=10&page=1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "analyses"],
              "query": [
                {
                  "key": "limit",
                  "value": "10"
                },
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "status",
                  "value": "completed",
                  "disabled": true
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Get Analysis details by ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{idToken}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/analyses/:analysisId",
              "host": ["{{baseUrl}}"],
              "path": ["api", "analyses", ":analysisId"],
              "variable": [
                {
                  "key": "analysisId",
                  "value": "ANALYSIS_DOCUMENT_UUID"
                }
              ]
            }
          },
          "response": []
        },
